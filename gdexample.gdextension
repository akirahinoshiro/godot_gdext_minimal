[configuration]

entry_symbol = "example_library_init"
compatibility_minimum = "4.6"
reloadable = true

[libraries]
linux.debug.x86_64 = "../../godot_gdext_minimal/build/libgdexampled.so"
linux.release.x86_64 = "../../godot_gdext_minimal/build/libgdexample.so"
windows.debug.x86_64 = "./bin/libgdexample.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "./bin/libgdexample.windows.template_release.x86_64.dll"
